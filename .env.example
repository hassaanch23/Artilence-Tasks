# ============================================================
#  Copy this file to `.env` and paste in your key.
#  `.env` is gitignored and must NEVER be committed.
# ============================================================

# ---- OpenAI (chat model + embeddings) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small

# ---- FAQ knowledge base (RAG) ----
FAQ_PATH=data/faqs.md
INDEX_DIR=faiss_index
CHUNK_SIZE=500
CHUNK_OVERLAP=80
TOP_K=3

# ---- Persona ----
COMPANY=Aurora Mobility

# NOTE: the live tools use keyless public APIs (Open-Meteo for weather,
# Yahoo Finance for stock) — no extra keys required.
