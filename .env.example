# ============================================================
#  Copy this file to `.env` and fill in your keys.
#  `.env` is gitignored and must NEVER be committed.
# ============================================================

# ---- OpenAI (required: chat model + embeddings for vector memory) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small

# ---- Google Custom Search (OPTIONAL) ----
# Leave BOTH blank to use keyless DuckDuckGo search (works out of the box).
# For the real Google Search API, create a Programmable Search Engine
# (https://programmablesearchengine.google.com) + an API key, then set both:
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# ---- Long-term memory ----
# SQLite file, created automatically. For PostgreSQL, see src/store.py.
DB_PATH=research_assistant.db
