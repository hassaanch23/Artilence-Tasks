
# Which provider to use by default: "openai" or "huggingface"
# We default to huggingface because it needs no API key.
LLM_PROVIDER=huggingface

# ---- OpenAI (only needed when LLM_PROVIDER=openai) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Hugging Face (runs locally, no key needed) ----
# flan-t5-base is small (~250M) and follows instructions,
# which is ideal for prompt-engineering demos on a laptop.
HF_MODEL=google/flan-t5-base
