# ============================================================
#  Copy this file to `.env` and paste in your key.
#  `.env` is gitignored and must NEVER be committed.
# ============================================================

# ---- OpenAI (chat model + embeddings) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small

# ---- Retrieval / chunking (sensible defaults; tune if you like) ----
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=4

# ---- FAISS index location (created by `python -m src.ingest <pdf>`) ----
INDEX_DIR=faiss_index
